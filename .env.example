# ===== Valley Server Configuration =====
VALLEY_PORT=3000
VALLEY_DB_PATH=./valley/server/data/monuments.db

# ===== Data Burning =====
# Burn passes: 1 (fast), 3 (DoD 5220.22-M), 7 (Gutmann)
BURN_PASSES=3
