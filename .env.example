# ===== AI Provider Configuration =====
# Choose your AI provider: deepseek | claude | openai | ollama | qwen | glm | gemini
AI_PROVIDER=deepseek

# DeepSeek API (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Anthropic Claude API (optional)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API (optional)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Alibaba Qwen / 通义千问 (optional)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Zhipu GLM / 智谱清言 (optional)
GLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API (optional)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Local Ollama Configuration (完全离线，无需 API Key) =====
# 安装 Ollama: https://ollama.ai/
# 拉取模型: ollama pull qwen2:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b

# ===== Feishu API Configuration (optional) =====
# Get credentials: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Valley Server Configuration =====
VALLEY_PORT=3001
VALLEY_DB_PATH=./valley/server/data/valley.db

# JWT 密钥（必需，用以下命令生成随机密钥）:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_here

# ===== Data Burning =====
# Burn passes: 1 (fast), 3 (DoD 5220.22-M), 7 (Gutmann)
BURN_PASSES=3
